# 1. 在自己機器上 clone 並建分支
git clone https://github.com/lide015/crownsupply.git
cd crownsupply
git checkout -b claude/begin-system-construction-oZFpE main

# 2. 刪除靜態檔
git rm 404.html about.html case-studies.html checkout.html contact.html \
       index.html industry-packs.html note-detail.html notes.html partners.html \
       privacy.html products.html resources.html services.html styles.css \
       terms.html thank-you.html vercel.json README.md

# 3. 把 crown-market-room-v2.zip 解開，內容物移到根目錄
unzip /path/to/crownmarketroomv2_2.zip
mv crown-market-room-v2/* crown-market-room-v2/.[!.]* ./
rmdir crown-market-room-v2

# 4. 在 .gitignore 末尾加上
echo -e "\n# SQLite database (auto-generated by prisma db push)\nprisma/*.db\nprisma/*.db-journal" >> .gitignore

# 5. commit + push
git add -A
git commit -m "Migrate to CROWN MARKET ROOM v2 scaffold"
git push -u origin claude/begin-system-construction-oZFpE
